# انسخ هذا الملف باسم .env.local (بدون .example) وحط قيمك الحقيقية
# خذها من Supabase > Settings > API

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# ⚠️ ملاحظة مهمة:
# - لا تحط Service Role Key هنا أبداً - نستخدم بس anon key بهذا المشروع
# - ملف .env.local ما يترفع لـ GitHub تلقائياً (موجود بـ .gitignore) - هذا مقصود وآمن
# - إذا نشرت الموقع على Vercel، تحط نفس هذولين المتغيرين بإعدادات المشروع هناك
#   (Project Settings > Environment Variables)
